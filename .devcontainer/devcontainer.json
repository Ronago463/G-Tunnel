{
  "name": "ghtun-warzone",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "postAttachCommand": "gh codespace ports visibility 443:public -c $CODESPACE_NAME && sudo cp /app/start.sh /etc/start.sh && sudo chmod +x /etc/start.sh && sudo bash /etc/start.sh",
  "portsAttributes": {
    "443": {
      "label": "xray-ws",
      "protocol": "https",
      "onAutoForward": "silent"
    }
  },
  "forwardPorts": [443],
  "hostRequirements": {
    "cpus": 2
  }
}